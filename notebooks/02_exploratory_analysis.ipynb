   "metadata": {},
   "outputs": [],
   "source": [
    "df = pd.read_csv(\"../data/processed/clean_activities.csv\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 62,
   "id": "1ae5e6b0",
   "metadata": {},
   "outputs": [],
   "source": [
    "df[\"activity_date\"] = pd.to_datetime(df[\"activity_date\"], errors=\"coerce\")\n",
    "df = df.dropna(subset=[\"activity_date\"])\n",
    "df = df.sort_values(\"activity_date\")\n",
    "df = df[df[\"avg_speed\"] > 2]"
   ]
  },
