   "source": [
    "df = df.sort_values(\"activity_date\")\n",
    "\n",
    "df[\"rolling_speed\"] = df[\"avg_speed\"].rolling(window=10).mean()\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(12, 6))\n",
    "\n",
    "ax.plot(df[\"activity_date\"], df[\"avg_speed\"], alpha=0.3, label=\"Raw Speed\")\n",
    "ax.plot(df[\"activity_date\"], df[\"rolling_speed\"], label=\"Rolling Avg\")\n",
    "\n",
    "ax.set_title(\"Performance Trend Over Time\")\n",
    "ax.set_xlabel(\"Date\")\n",
    "ax.set_ylabel(\"Average Speed\")\n",
    "\n",
    "# 1 tick tous les 3 mois\n",
    "ax.xaxis.set_major_locator(mdates.MonthLocator(interval=3))\n",
    "ax.xaxis.set_major_formatter(mdates.DateFormatter(\"%Y-%m\"))\n",
    "\n",
    "plt.xticks(rotation=45)\n",
    "plt.grid(alpha=0.3)\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
