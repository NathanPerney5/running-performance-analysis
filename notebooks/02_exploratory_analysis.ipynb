   ],
   "source": [
    "weekly_distance = df.resample(\"W\", on=\"activity_date\")[\"distance_km\"].sum()\n",
    "\n",
    "plt.figure(figsize=(12,6))\n",
    "weekly_distance.plot()\n",
    "plt.title(\"Weekly Training Volume\")\n",
    "plt.ylabel(\"Distance (km)\")\n",
    "plt.xlabel(\"Date\")\n",
    "plt.savefig(\"../visuals/weekly_training_volume.png\", dpi=300)\n",
    "plt.show()\n"
    
   ]
