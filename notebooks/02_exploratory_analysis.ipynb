   "source": [
    "rolling_load = weekly_distance.rolling(window=4).mean()\n",
    "plt.figure(figsize=(12,6))\n",
    "\n",
    "plt.plot(weekly_distance, label=\"Weekly Load\")\n",
    "plt.plot(rolling_load, label=\"4-week Average\", linestyle=\"--\")\n",
    "\n",
    "plt.title(\"Training Load vs Rolling Average\")\n",
    "plt.ylabel(\"Distance (km)\")\n",
    "plt.legend()\n",
    "plt.savefig(\"../visuals/training_load_vs_rolling_avg.png\", dpi=300)"
    "plt.show()\n",
    
   ]
